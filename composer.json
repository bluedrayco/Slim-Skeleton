{
    "name": "slim/slim2-skeleton",
    "description": "A Slim 2 Framework for create projects fast",
    "keywords": [
        "MVC",
        "rest",
        "router",
        "psr7",
        "twig"
    ],
    "homepage": "https://github.com/bluedrayco/Slim-Skeleton",
    "license": "MIT",
    "authors": [
        {
            "name": "Roberto Leroy Monroy Ruiz",
            "email": "bluedrayco@gmail.com"
        }
    ],
    "require": {
        "php": ">=5.3.0",
        "monolog/monolog": "1.*",
        "slim/slim": "2.*",
        "slim/views": "0.*",
        "twig/twig": "1.*",
        "vlucas/phpdotenv":"v5.*",
        "illuminate/database": "^8.54",
        "robmorgan/phinx": "0.11.7"
    },
    "autoload":{
        "psr-0":{
            "Controller":"src"
        }
    },
    "scripts":{
        "start": "php -S 0.0.0.0:8000 -t public"
    }
}
